{
  "name": "hl-cex-tracker",
  "version": "2.0.0",
  "description": "Mirror Hyperliquid on-chain positions to Binance Futures in real-time",
  "main": "dist/index.js",
  "bin": {
    "hl-cex-tracker": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "follow": "ts-node src/index.ts follow",
    "status": "ts-node src/index.ts status",
    "positions": "ts-node src/index.ts positions",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "hyperliquid",
    "binance",
    "futures",
    "copy-trading",
    "on-chain",
    "cryptocurrency",
    "cli"
  ],
  "author": "Nof1 Trading Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "commander": "^11.1.0",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.4",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
