# Hyperliquid Configuration
# 要监控的 Hyperliquid 链上钱包地址
HYPERLIQUID_TARGET_ADDRESS=0xYourWalletAddressHere
# 是否使用测试网
HYPERLIQUID_TESTNET=false
# 轮询间隔（毫秒），默认 3000ms
HYPERLIQUID_POLL_INTERVAL_MS=3000

# Binance Futures API
# ⚠️ 重要：必须启用合约交易权限 (Enable Futures)
# 获取方式：https://www.binance.com/en/my/settings/api-management
# 测试网：https://testnet.binancefuture.com/
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
# 是否使用测试网环境（推荐新手先使用测试网）
BINANCE_TESTNET=true

# Trading Configuration
# 跟单比例：1.0 = 与源地址等比，0.1 = 源地址的10%，2.0 = 2倍
FIXED_RATIO=1.0
# 保证金模式：CROSSED（全仓）或 ISOLATED（逐仓）
MARGIN_TYPE=CROSSED
# 价格容差百分比（偏离源地址入场价超过此百分比不执行）
PRICE_TOLERANCE_PERCENT=1.0

# Logging
# 日志级别: ERROR, WARN, INFO (默认), DEBUG, VERBOSE
LOG_LEVEL=INFO